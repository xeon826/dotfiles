{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": true,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": false
  },
  "agents": {
    "plan": {
      "model": "anthropic/claude-haiku-4-5",
      "disable": false,
      "description": "Planning agent for task decomposition",
      "mode": "primary"
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-6",
      "disable": false,
      "description": "Build and execution agent",
      "mode": "primary"
    },
    "OpenCode-Builder": {
      "model": "zai-coding-plan/glm-4.7",
      "disable": false,
      "description": "Alternative builder agent",
      "mode": "subagent"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "chutes/moonshotai/Kimi-K2.5-TEE",
    },
    "ultrabrain": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "quick": {
      "model": "zai-coding-plan/glm-4.7",
    },
    "unspecified-low": {
      "model": "zai-coding-plan/glm-4.7",
    },
    "unspecified-high": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "writing": {
      "model": "chutes/moonshotai/Kimi-K2.5-TEE",
    },
  },
}
