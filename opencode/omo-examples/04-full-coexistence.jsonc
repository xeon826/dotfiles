{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": false
  },
  "agents": {
    "sisyphus": {
      "model": "zai-coding-plan/glm-4.7",
      "disable": false,
      "description": "OMO orchestrator agent",
      "mode": "primary"
    },
    "oracle": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "librarian": {
      "model": "deepseek/deepseek-reasoner",
    },
    "explore": {
      "model": "deepseek/deepseek-reasoner",
    },
    "multimodal-looker": {
      "model": "chutes/zai-org/GLM-4.6V",
    },
    "prometheus": {
      "model": "chutes/moonshotai/Kimi-K2.5-TEE",
    },
    "metis": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "momus": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "atlas": {
      "model": "zai-coding-plan/glm-4.7",
    },
    "hephaestus": {
      "model": "zai-coding-plan/glm-4.7",
    },
    "plan": {
      "model": "anthropic/claude-haiku-4-5",
      "disable": false,
      "description": "Planning agent for task decomposition",
      "mode": "primary",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-6",
      "disable": false,
      "description": "Build and execution agent",
      "mode": "primary",
      "temperature": 0.2
    },
    "OpenCode-Builder": {
      "model": "zai-coding-plan/glm-4.7",
      "disable": false,
      "description": "Alternative builder agent",
      "mode": "subagent"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "chutes/moonshotai/Kimi-K2.5-TEE",
    },
    "ultrabrain": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "quick": {
      "model": "zai-coding-plan/glm-4.7",
    },
    "unspecified-low": {
      "model": "zai-coding-plan/glm-4.7",
    },
    "unspecified-high": {
      "model": "chutes/deepseek-ai/DeepSeek-V3.2-TEE",
    },
    "writing": {
      "model": "chutes/moonshotai/Kimi-K2.5-TEE",
    },
  },
}
